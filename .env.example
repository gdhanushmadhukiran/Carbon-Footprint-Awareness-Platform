# EcoTrack AI — Environment Variables
# Copy this file to .env and add your API key

# Google Gemini API Key (for AI Climate Coach, Weekly Reports, Challenge Generator)
# Get yours at: https://aistudio.google.com/apikey
# The app works without this (uses local rules-based fallback), but the AI
# features will be much more personalized with a real API key.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
